<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.StudentListPage"
             xmlns:viewmodels="clr-namespace:MauiApp1.Viewmodels"
             xmlns:dto="clr-namespace:MauiApp1.DTOs"
             Title="Alumnos">

    <Grid RowDefinitions="Auto, Auto, *" Padding="10">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
            <SearchBar  Grid.Column="0"
                        Placeholder="Buscar..."
                        Text="{Binding SearchText}"
                        Margin="0,0,10,0"/>

            <Button Grid.Column="1"
                    Text="Nuevo"
                    Command="{Binding AddNewStudentCommand}"
                    HorizontalOptions="Center" 
                    Padding="10"/>
        </Grid>
        <Label Grid.Row="1" Margin="0,0,0,10" Text="Lista de alumnos registrados."/>
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Students}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="5" Orientation="Vertical"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:StudentDTO">
                    <Border Padding="12" BackgroundColor="{StaticResource Gray950}" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, Auto, Auto">
                            <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} {1} {2}">
                                        <Binding Path="Name"/>
                                        <Binding Path="PaternalSurname"/>
                                        <Binding Path="MaternalSurname"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Grid.Row="1" Grid.Column="0" Text="{Binding Code, StringFormat='Codigo: {0}'}" />
                            <Label Grid.Row="2" Grid.Column="0" Text="{Binding BeltDescription, StringFormat='Grado: {0}'}" />

                            <Button Grid.Row="0" Grid.Column="1" Text="Editar"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:StudentListVM}}, Path=EditStudentCommand}"
                                CommandParameter="{Binding .}"
                                Margin="0,0,5,0" />
                            <Button Grid.Row="0" Grid.Column="2" Text="Eliminar" BackgroundColor="Red" TextColor="White"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:StudentListVM}}, Path=DeleteStudentCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No hay alumnos registrados." HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50,0,0" FontSize="Medium" />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>