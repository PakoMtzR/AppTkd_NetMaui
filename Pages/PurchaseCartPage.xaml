<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.PurchaseCartPage"
             xmlns:vm="clr-namespace:MauiApp1.Viewmodels"
             xmlns:dto="clr-namespace:MauiApp1.DTOs"
             x:DataType="vm:PurchaseCartVM"
             Title="Revisar Pedido">

    <Grid RowDefinitions="*, Auto" Padding="20">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:PurchaseOrderDetailDTO">
                    <Border Margin="0,0,0,10" Padding="10" StrokeThickness="0" Background="{StaticResource Gray950}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding ProductName}" FontAttributes="Bold" />
                                <Label Text="{Binding UnitPriceAtPurchase, StringFormat='Costo Unitario: {0:C}'}" FontSize="12" />
                                <Label Text="{Binding TotalCost, StringFormat='Subtotal: {0:C}'}" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            
                            <!-- Control de Cantidad -->
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Start" Spacing="5" Margin="0,0,10,0">
                                <Button Text="-" 
                                        WidthRequest="40" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PurchaseCartVM}}, Path=DecreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"/>
                                <Label Text="{Binding Quantity}" 
                                       VerticalOptions="Center" 
                                       FontSize="18" 
                                       WidthRequest="30" 
                                       HorizontalTextAlignment="Center"/>
                                <Button Text="+" 
                                        WidthRequest="40" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PurchaseCartVM}}, Path=IncreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>

                            <Button Grid.Column="2" VerticalOptions="Start"
                                    Text="Eliminar" 
                                    BackgroundColor="Red" 
                                    TextColor="White"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PurchaseCartVM}}, Path=RemoveItemCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Totales -->
        <Border Grid.Row="1" Padding="10" BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}" StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5"/>
            </Border.StrokeShape>
            <VerticalStackLayout  Spacing="10" >
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Subtotal Productos:" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{Binding TotalOrder, StringFormat='{0:C}'}" FontAttributes="Bold" />
                </Grid>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Costo de Envío:" VerticalOptions="Center" />
                    <Entry Grid.Column="1" Text="{Binding ShipmentCost}" Keyboard="Numeric" HorizontalTextAlignment="End" WidthRequest="100" />
                </Grid>
                <BoxView HeightRequest="1" Color="Gray" />
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="COSTO TOTAL:" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding GrandTotal, StringFormat='{0:C}'}" FontSize="20" FontAttributes="Bold"/>
                </Grid>
                <Button Text="Confirmar y Sumar a Inventario" 
                        Command="{Binding FinalizePurchaseCommand}"
                        BackgroundColor="Blue" TextColor="White" HeightRequest="50" Margin="0,10,0,0" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
