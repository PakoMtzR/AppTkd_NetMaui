<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Pages.CartPage"
             xmlns:vm="clr-namespace:MauiApp1.Viewmodels"
             xmlns:dto="clr-namespace:MauiApp1.DTOs"
             x:DataType="vm:CartVM"
             Title="Carrito de Venta">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Datos del cliente -->
        <Entry Placeholder="Nombre del Cliente (Opcional)"
               Text="{Binding ClientName}" />

        <!-- Lista de productos en el carrito -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,20">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:SaleDetailDTO">
                    <Border Margin="0,0,0,10" Padding="10" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="5"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding ProductName}" FontAttributes="Bold" />
                                <Label Text="{Binding ProductPrice, StringFormat='Precio Unitario: {0:C}'}" FontSize="12" />
                                <Label Text="{Binding TotalPrice, StringFormat='Subtotal: {0:C}'}" FontAttributes="Bold" />
                            </VerticalStackLayout>
                            
                            <!-- Control de Cantidad -->
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5" Margin="0,0,10,0">
                                <Button Text="-" 
                                        WidthRequest="40" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartVM}}, Path=DecreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"/>
                                <Label Text="{Binding Quantity}" 
                                       VerticalOptions="Center" 
                                       FontSize="18" 
                                       WidthRequest="30" 
                                       HorizontalTextAlignment="Center"/>
                                <Button Text="+" 
                                        WidthRequest="40" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartVM}}, Path=IncreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>

                            <Button Grid.Column="2" 
                                    Text="Eliminar" 
                                    BackgroundColor="Red" 
                                    TextColor="White"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CartVM}}, Path=RemoveItemCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Finalizar Venta -->
        <VerticalStackLayout Grid.Row="2" Spacing="10">
            <Label Text="{Binding Total, StringFormat='Total a Pagar: {0:C}'}" 
                   FontSize="22" FontAttributes="Bold" HorizontalOptions="End" />
            <Button Text="Concretar Venta" 
                    Command="{Binding FinalizeSaleCommand}"
                    BackgroundColor="Green" 
                    TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
