<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.Viewmodels"
             xmlns:dto="clr-namespace:MauiApp1.DTOs"
             x:Class="MauiApp1.Pages.SaleDetailPage"
             x:DataType="viewmodels:SaleDetailVM"
             Title="Detalle de Venta">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- Encabezado de la Venta -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#333333}" Padding="15">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding Sale.SaleNumber, StringFormat='Folio: {0}'}" 
                           FontSize="20" FontAttributes="Bold" />
                    <Label Text="{Binding Sale.RegistrationDate, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}" 
                           FontSize="14" />
                    <Label Text="{Binding Sale.ClientName, StringFormat='Cliente: {0}'}" 
                           FontSize="16" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Productos Comprados" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0" />

            <!-- Lista de Productos -->
            <CollectionView ItemsSource="{Binding Sale.SaleDetails}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:SaleDetailDTO">
                        <Frame Margin="0,0,0,10" Padding="10">
                            <Grid ColumnDefinitions="*, Auto, Auto" RowDefinitions="Auto, Auto">
                                <Label Text="{Binding ProductName}" FontAttributes="Bold" Grid.ColumnSpan="3" />
                                
                                <Label Grid.Row="1" Grid.Column="0" 
                                       Text="{Binding Quantity, StringFormat='Cant: {0}'}" FontSize="14" />
                                
                                <Label Grid.Row="1" Grid.Column="1" 
                                       Text="{Binding ProductPrice, StringFormat='Precio: {0:C}'}" 
                                       FontSize="14" Margin="10,0" />
                                
                                <Label Grid.Row="1" Grid.Column="2" 
                                       Text="{Binding TotalPrice, StringFormat='Subtotal: {0:C}'}" 
                                       FontAttributes="Bold" FontSize="14" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Total General -->
            <Frame BackgroundColor="Green" Padding="15" HorizontalOptions="Fill">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Label Text="TOTAL PAGADO:" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label Text="{Binding Sale.TotalPrice, StringFormat='{0:C}'}" 
                           TextColor="White" FontSize="22" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
